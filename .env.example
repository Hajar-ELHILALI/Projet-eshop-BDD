# ============================================================
# Variables d'environnement - EShop BDD Distribuee (MODELE)
# Copier ce fichier en .env puis renseigner les mots de passe :
#     cp .env.example .env
# ============================================================

# Mot de passe du compte SYS Oracle (administrateur du conteneur)
ORACLE_PASSWORD=changez_moi_sys

# Mot de passe commun des comptes applicatifs (eshop_admin, site1, site2, backup)
APP_USER_PASSWORD=changez_moi_app

# Mot de passe du compte connecteur des DB Links (eshop_link)
LINK_PASSWORD=changez_moi_link

# Schemas applicatifs par noeud
MASTER_USER=eshop_admin
SITE1_USER=eshop_site1
SITE2_USER=eshop_site2
BACKUP_USER=eshop_backup

# Ports exposes sur l'hote (format host:1521)
MASTER_PORT=1524
SITE1_PORT=1522
SITE2_PORT=1523
BACKUP_PORT=1525

# Repertoire TNS dans les conteneurs
TNS_ADMIN=/opt/oracle/network/admin
